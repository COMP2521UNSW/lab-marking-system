{
	"endOfLine": "lf",
	"importOrder": [
		"<BUILTIN_MODULES>",
		"<THIRD_PARTY_MODULES>",
		"^@workspace/",
		"^@@?/",
		"^./"
	],
	"importOrderSeparation": true,
	"importOrderSideEffects": false,
	"plugins": [
		"@trivago/prettier-plugin-sort-imports",
		"prettier-plugin-packagejson"
	],
	"printWidth": 80,
	"semi": true,
	"singleQuote": true,
	"tabWidth": 2,
	"useTabs": true
}
